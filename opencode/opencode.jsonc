{
  "$schema": "https://opencode.ai/config.json",

  // ---------------------------------------------------------------------------
  // Why this file exists
  // ---------------------------------------------------------------------------
  // Claude Code and Codex both expose a *runtime* switch to eliminate every
  // permission prompt for a session:
  //
  //   Claude Code   claude --dangerously-skip-permissions
  //   Codex         codex  --dangerously-bypass-approvals-and-sandbox  (alias: --yolo)
  //
  // OpenCode has no equivalent "skip all permissions" flag. The only way to run
  // it without approval prompts is to declare it in config. This file is that
  // config, kept here as the source of truth and synced to the live location:
  //
  //   opencode/opencode.jsonc  ->  ~/.config/opencode/opencode.jsonc
  //
  // ---------------------------------------------------------------------------
  // What it does
  // ---------------------------------------------------------------------------
  // Never prompt for anything. Every permission is "allow".
  //
  // The usual culprits for surprise prompts are NOT bash patterns:
  //   - reading ~/.agents/rules and writing /tmp are gated by
  //     "external_directory", which defaults to "ask" for any path outside the
  //     project directory opencode was launched in. "allow" here silences those.
  //
  // The two "deny" bash patterns block silently (no prompt) as a last-resort
  // safety net against unrecoverable disk wipes — remove them for full allow.
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "task": "allow",
    "skill": "allow",
    "lsp": "allow",
    "question": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "external_directory": "allow",
    "doom_loop": "allow",
    "bash": {
      "*": "allow",
      "mkfs *": "deny",
      "dd *": "deny"
    }
  },

  "provider": {
    "minimax": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MiniMax OpenAI-Compatible",
      "options": {
        "baseURL": "https://api.minimax.io/v1",
        "setCacheKey": true
      },
      "models": {
        "MiniMax-M3": {
          "name": "MiniMax M3",
          "limit": {
            "context": 512000,
            "output": 64000
          },
          "reasoning": true,
          "tool_call": true,
          "options": {
            "reasoning_split": true
          },
          "cost": {
            "input": 3e-7,
            "output": 1.2e-6,
            "cache_read": 6e-8
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    },
    "minimax-coding-plan": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MiniMax OpenAI-Compatible",
      "options": {
        "baseURL": "https://api.minimax.io/v1",
        "setCacheKey": true
      },
      "models": {
        "MiniMax-M3": {
          "name": "MiniMax M3",
          "limit": {
            "context": 512000,
            "output": 64000
          },
          "reasoning": true,
          "tool_call": true,
          "options": {
            "reasoning_split": true
          },
          "cost": {
            "input": 3e-7,
            "output": 1.2e-6,
            "cache_read": 6e-8
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    },
    "wafer.ai": {
      "models": {
        "GLM-5.2": {
          "name": "GLM-5.2",
          "family": "glm",
          "release_date": "2026-06-13",
          "limit": {
            "context": 1000000,
            "output": 131072
          },
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "interleaved": {
            "field": "reasoning_content"
          },
          "cost": {
            "input": 1.2e-6,
            "output": 4.1e-6,
            "cache_read": 2e-7
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    }
  }
}
