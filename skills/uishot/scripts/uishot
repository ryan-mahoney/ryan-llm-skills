#!/bin/sh

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
UISHOT_SCRIPT="$SCRIPT_DIR/uishot.py"
export UISHOT_COMMAND="$SCRIPT_DIR/uishot"

if command -v uv >/dev/null 2>&1; then
    exec uv run --script "$UISHOT_SCRIPT" "$@"
fi

if command -v python3 >/dev/null 2>&1 &&
    python3 -c 'import playwright' >/dev/null 2>&1; then
    exec python3 "$UISHOT_SCRIPT" "$@"
fi

printf '%s\n' \
    'error: dependency-runner-not-found' \
    'detail: uishot needs uv, or Python 3 with Playwright already installed' \
    'next_action: install uv, then rerun this command'
exit 7
